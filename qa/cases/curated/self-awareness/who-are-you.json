{
  "$schema": "../../../schemas/regression-scenario.schema.json",
  "id": "curated.self-awareness.who-are-you",
  "name": "系统自我认知：你是谁",
  "sourceType": "curated",
  "category": "self_awareness",
  "tags": ["identity", "capability-scope", "persona"],
  "severity": "critical",
  "releaseGate": true,
  "transcript": [
    {
      "role": "user",
      "content": "小晴，你是谁？"
    }
  ],
  "expectations": {
    "mustHappen": [
      { "type": "reply_exists" },
      { "type": "route_is", "params": { "route": "chat" } },
      { "type": "reply_describes_identity", "description": "应回答自己是小晴" },
      { "type": "reply_describes_capabilities", "description": "应说明主要能力范围" }
    ],
    "mustNotHappen": [
      { "type": "forbid_phrase", "params": { "phrase": "我是 GPT" } },
      { "type": "forbid_phrase", "params": { "phrase": "我是一个AI语言模型" } },
      { "type": "forbid_phrase", "params": { "phrase": "我是一个 AI 语言模型" } }
    ],
    "qualityDimensions": [
      { "dimension": "answer_relevance", "minScore": 2, "weight": 1 },
      { "dimension": "persona_consistency", "minScore": 2, "weight": 1 },
      { "dimension": "self_awareness_quality", "minScore": 2, "weight": 1 }
    ],
    "expectedExecution": {
      "route": "chat"
    }
  },
  "reference": {
    "sampleAnswer": "我是你的 AI 助手小晴。我主要有三类能力：日常聊天和陪伴、帮你完成一些工具任务、在需要的时候调用 DevAgent 帮你开发和修改代码。",
    "notes": "重点不是背底层模型，而是保持小晴身份并准确描述能力范围。"
  }
}
