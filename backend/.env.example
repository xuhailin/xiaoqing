# PostgreSQL (local example)
DATABASE_URL="postgresql://postgres@localhost:5432/chat?schema=public"

# Optional: API port
PORT=3000

# ── Agent Bus 反向 Tunnel（本机小晴暴露给远端 Agent 服务器）────────────────
# SSH alias，建议在 ~/.ssh/config 中配置为 xiaoqin-server
AGENT_BUS_REMOTE_HOST=xiaoqin-server
# 服务器本机暴露的端口；远端 Agent 访问 http://127.0.0.1:${AGENT_BUS_REMOTE_PORT}
AGENT_BUS_REMOTE_PORT=18080
# 小晴本地监听端口；默认跟随 PORT
AGENT_BUS_LOCAL_PORT=3000
# 可选：健康检查路径，wrapper 会等待此地址成功后再开 tunnel
AGENT_BUS_HEALTH_PATH=/agent-bus/inbound/health
# 可选：后端启动等待秒数
AGENT_BUS_STARTUP_TIMEOUT_SECONDS=45

# Frontend origin for CORS (comma-separated; 桌面端开发时需含 http://localhost:1420)
CORS_ORIGIN=http://localhost:4200,http://localhost:1420

# LLM 配置（智谱 GLM / OpenAI 兼容）
LLM_API_KEY=                                          # 智谱 API Key（从 open.bigmodel.cn 获取）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/   # 智谱 API 地址（也可换为 OpenAI 等兼容 API）
LLM_MODEL=glm-4.7                                     # 模型名称
LLM_MAX_TOKENS=4096                                    # 最大输出 token 数

# Conversation context size (default 8 rounds)
CONVERSATION_LAST_N_ROUNDS=8

# Feature flag 约定：
# - 仅保留 rollout / 高成本 / 高风险 / 外部执行器类开关。
# - 若能力是否可用已经能由具体配置判断（如 URL、账号、API Key），不要再叠一层 FEATURE_*。

# Phase2: Memory injection - how many mid-term memories to inject (default 5, fallback only)
MEMORY_INJECT_MID_K=5

# Phase3: Max context tokens before truncation (default 3000)
MAX_CONTEXT_TOKENS=3000

# ── Memory Injection v2: System prompt budget ──────────────────────────────
# System prompt token 上限（persona + impression + memories，默认 1200）
MAX_SYSTEM_TOKENS=1200

# ── Memory Injection v2: Candidate recall ─────────────────────────────────
# 候选集：long memory 最大取量（默认 15，多取后再评分缩减）
MEMORY_CANDIDATES_MAX_LONG=15
# 候选集：mid memory 最大取量（默认 20）
MEMORY_CANDIDATES_MAX_MID=20
# LLM 精排触发阈值：候选数超过此值才调用 LLM（默认 5）
MIN_CANDIDATES_FOR_LLM_RANK=5
# 单条 memory content 最大字符数，超长时截断（默认 300）
MEMORY_CONTENT_MAX_CHARS=300
# long memory 关键词相关性最低分，低于此值标记 deferred（默认 0.05）
MEMORY_MIN_RELEVANCE_SCORE=0.05

# ── Memory Injection v2: Feature flags ────────────────────────────────────
# 注入核心印象到 system prompt（默认 true，设为 false 关闭）
FEATURE_IMPRESSION_CORE=true
# needDetail 时注入可选细节（默认 false，Phase2b 后开启）
FEATURE_IMPRESSION_DETAIL=false
# 关键词预筛候选集（默认 true，设为 false 退回全量注入）
FEATURE_KEYWORD_PREFILTER=true
# LLM 精排（默认 false，成本较高；Phase2b 稳定后开启）
FEATURE_LLM_RANK=false
# Budget-aware 动态 Top-K（默认 true）
FEATURE_DYNAMIC_TOPK=true
# 使用 shortSummary 注入（默认 false，Phase3 功能）
FEATURE_MEMORY_SHORT_SUMMARY=false
# 返回 debugMeta 调试信息（默认 false，前端调试面板用）
FEATURE_DEBUG_META=false

# ── Claim Engine（用户画像 Claim 重构，灰度开关）────────────────────────
# 默认均为 false（代码仅在值为 "true" 时开启）
# 灰度顺序建议：
# 1) 先开双写：FEATURE_CLAIM_WRITE_DUAL=true
# 2) 观察后开读新（不注入）：FEATURE_CLAIM_READ_NEW=true
# 3) 再开注入：FEATURE_CLAIM_INJECTION=true
# 4) 最后开短期状态注入：FEATURE_SESSIONSTATE_INJECTION=true
FEATURE_CLAIM_WRITE_DUAL=false
# 子开关：即使双写开启，也仅在对应为 true 时写入新增类型（默认 false）
FEATURE_CLAIM_WRITE_INTERACTION=false
FEATURE_CLAIM_WRITE_EMOTION=false
# 两阶段治理：允许 draft.* claim 候选池（默认 false）
FEATURE_CLAIM_DRAFT_ENABLED=false
FEATURE_CLAIM_READ_NEW=false
FEATURE_CLAIM_INJECTION=false
FEATURE_SESSIONSTATE_INJECTION=false
# claim 注入 token 预算（默认 220）
CLAIM_INJECTION_TOKEN_BUDGET=220
# canonical 映射阈值（低于该值时，canonical 会降级为 draft）
CLAIM_CANONICAL_MAPPING_THRESHOLD=0.72

# ── Auto Summarize（对话中自动触发记忆提取）──────────────────────────
# 自动触发总结（默认 true，每 N 条用户消息后异步执行，不阻塞聊天）
FEATURE_AUTO_SUMMARIZE=true
# 触发阈值：summarizedAt 之后累计 N 条用户消息时触发（默认 15）
AUTO_SUMMARIZE_THRESHOLD=15
# 即时触发总结：关键词命中时立即总结（默认 true）
FEATURE_INSTANT_SUMMARIZE=true

# ── Memory Scheduler（定时衰减重算 + 记忆晋升/降级）─────────────────────
# 启用定时任务（默认 true；关闭后衰减重算和晋升/降级均不执行）
FEATURE_MEMORY_SCHEDULER=true
# mid → long 晋升：最少命中次数（默认 5）
MEMORY_PROMOTE_MIN_HITS=5
# mid → long 晋升：最少存活天数（默认 7）
MEMORY_PROMOTE_MIN_AGE_DAYS=7
# long → mid 降级：未命中天数阈值（默认 30）
MEMORY_DEMOTE_INACTIVE_DAYS=30

# ── Auto Impression（总结后自动提取印象变化）──────────────────────────
# 总结后自动提取印象变化并追加到 impressionCore（默认 true）
FEATURE_AUTO_IMPRESSION=true
# 印象更新是否需要人工确认（默认 false；false=自动直接写入 impressionCore）
FEATURE_IMPRESSION_REQUIRE_CONFIRM=false
# 总结后自动提取身份锚定（姓名、住址、职业等）写入 IdentityAnchor 表（默认 true）
FEATURE_AUTO_ANCHOR=true

# ── Evolution Scheduler（记忆密度触发人格进化建议）───────────────────
# 启用记忆密度检查 → 自动生成进化建议（默认 true；建议仍需人工确认）
FEATURE_EVOLUTION_SCHEDULER=true
# 触发阈值：某认知分类的活跃 long 记忆 >= N 条时触发（默认 5）
EVOLUTION_DENSITY_THRESHOLD=5

# ── OpenClaw 集成（远端 Agent 直连，JSON + Bearer Token）──────────────────
# 启用 OpenClaw 集成（默认 false）
FEATURE_OPENCLAW=false

# ── 方式一：单 Agent 快速配置（向后兼容）──
# Agent ID（唯一标识）
OPENCLAW_BOT_ID=
# Bearer Token
OPENCLAW_TOKEN=
# 可选 HMAC-SHA256 签名密钥（公网建议配置）
OPENCLAW_SIGN_KEY=
# API 基地址
OPENCLAW_PLUGIN_BASE_URL=
# 任务超时秒数（默认 60）
OPENCLAW_TIMEOUT_SECONDS=60
# 意图置信度阈值，低于此值不走 OpenClaw（默认 0.7）
OPENCLAW_CONFIDENCE_THRESHOLD=0.7

# ── 方式二：多 Agent 注册（JSON 数组，与方式一可共存、ID 冲突时此处优先）──
# OPENCLAW_AGENTS='[{"id":"intel-cat","name":"情报喵","baseUrl":"https://your-server/api","token":"xxx","capabilities":["web-search","news"],"timeout":60,"apiStyle":"json"}]'
OPENCLAW_AGENTS=

# ── Claude Code Agent（自主编码执行器）──
# 启用 Claude Code Agent executor（默认 false）
FEATURE_CLAUDE_CODE=false
# Claude Code 使用的模型（默认 claude-sonnet-4-6）
CLAUDE_CODE_MODEL=claude-sonnet-4-6
# Claude Code 最大 agent 轮次（默认 50）
CLAUDE_CODE_MAX_TURNS=50
# Claude Code 单次任务最大花费 USD（默认 5.0）
CLAUDE_CODE_MAX_BUDGET_USD=5.0
# Claude Code 工作目录（默认为 process.cwd()）
# CLAUDE_CODE_PROJECT_ROOT=/path/to/project
# Dev reminder 调度器（默认 true；QA/离线脚本可显式设为 false）
FEATURE_DEV_REMINDER=true

# ── 本地天气 Skill（和风天气，查天气时优先执行，失败再走 OpenClaw）──
# 和风 API Key（控制台 https://console.qweather.com 创建项目获取）；不填则查天气直接走 OpenClaw
QWEATHER_API_KEY=
# 和风 API 基地址（可选，默认 https://devapi.qweather.com；若使用控制台分配的 API Host 请替换）
QWEATHER_BASE_URL=

# ── 电子书下载 Skill（问小晴「下载xxx」时走本地工具，需先 npm install 并构建 tools/ebook-downloader）──
# 若报「无法启动浏览器」，请在 tools/ebook-downloader 下执行：npx playwright install chromium
# 无单独 feature flag；是否可用由 RESOURCE_BASE_URL 是否配置决定
# 资源站根地址（必填才可用 book_download）
RESOURCE_BASE_URL=
# 可选：登录后搜索
RESOURCE_EMAIL=
RESOURCE_PASSWORD=
# 下载保存目录（默认 assets/books，相对后端进程 cwd）
BOOKS_DOWNLOAD_DIR=assets/books

# ── 本地基础行动能力（general_action：仅单步低风险 browser/file，默认关闭）──
# 开启后，当意图识别为 general_tool 时先尝试本地动作执行器。
FEATURE_LOCAL_GENERAL_ACTION=false
# 文件能力白名单（逗号分隔，支持相对路径，运行时解析为绝对路径）。
# 默认白名单基线：BOOKS_DOWNLOAD_DIR + 系统临时目录。
LOCAL_ACTION_FILE_ALLOWLIST=
# 浏览器动作默认无头（true）；设为 false 可观察窗口
LOCAL_ACTION_BROWSER_HEADLESS=true
# 本地基础行动超时（毫秒）
LOCAL_ACTION_TIMEOUT_MS=10000

# ── 打卡 Skill（考勤打卡，通过 Playwright 操控浏览器）───────────────────────
# 打卡目标首页 URL（必填才可用 checkin）
CHECKIN_TARGET_URL=
# SSO 登录页 URL 特征（URL 包含该字符串则判定需要登录，默认 sso/login）
CHECKIN_SSO_PATTERN=sso/login
# 打卡坐标（纬度/经度，默认上海）
CHECKIN_GEO_LAT=31.2304
CHECKIN_GEO_LNG=121.4737
# 扫码超时（毫秒，默认 300000 即 5 分钟）
CHECKIN_SCAN_TIMEOUT_MS=300000
# StorageState 持久化 key（默认 checkin）
CHECKIN_SITE_KEY=checkin
# 截图保存目录（默认 assets/checkin-debug）
CHECKIN_SCREENSHOT_DIR=assets/checkin-debug
# 页面操作超时（毫秒，默认 15000）
CHECKIN_TIMEOUT_MS=15000

# ── 工时上报 Skill（OA 自动录入工时，通过 Playwright 操控浏览器）───────────
# 启用工时上报技能（默认 false）
FEATURE_TIMESHEET=false
# OA 登录页地址
TIMESHEET_OA_URL=
# 登录后直达流程中心页（绕过门户 hover），默认带菜单参数
TIMESHEET_WORKFLOW_ENTRY_URL=""
# OA 登录名（工号）
TIMESHEET_LOGIN_ID=
# OA 登录密码
TIMESHEET_PASSWORD=
# 项目映射配置文件路径（相对后端 cwd 或绝对路径，JSON 数组）
TIMESHEET_PROJECTS_CONFIG=config/timesheet-projects.json
# git log --author 过滤（可选，不填则取所有提交）
TIMESHEET_GIT_AUTHOR=
# 失败截图保存目录
TIMESHEET_SCREENSHOT_DIR=assets/timesheet-debug
# 每步超时（毫秒，默认 15000）
TIMESHEET_TIMEOUT_MS=15000
