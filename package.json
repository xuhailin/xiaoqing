{
  "name": "xiaoqing",
  "version": "0.0.1",
  "private": true,
  "description": "LongMemory AI Companion (小晴) - 单仓根目录，用于从外层直接启动前端或后端",
  "scripts": {
    "start:frontend": "NINJA_ENV=production npm start --prefix frontend",
    "start:backend": "NINJA_ENV=production npm run start:dev --prefix backend",
    "frontend": "NINJA_ENV=production npm start --prefix frontend",
    "backend": "NINJA_ENV=production npm run start:dev --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend && npm install --prefix desktop",
    "desktop": "npm run tauri dev --prefix desktop",
    "desktop:dev": "npm run tauri dev --prefix desktop",
    "desktop:build": "npm run tauri build --prefix desktop"
  }
}
