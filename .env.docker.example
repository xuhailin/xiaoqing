# PostgreSQL for Docker Compose
POSTGRES_DB=xiaoqing
POSTGRES_USER=xiaoqing
POSTGRES_PASSWORD=change-me

# Frontend runtime API override.
# Leave blank to auto-resolve to http://<current-host>:3000
XQ_API_URL=
FRONTEND_PORT=80

# CORS: set this to your server IP, e.g. http://123.45.67.89
CORS_ORIGIN=http://YOUR_SERVER_IP

# Core runtime
APP_USER_MODE=single
DEFAULT_USER_KEY=default-user
PORT=3000

# LLM
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4.7
LLM_MAX_TOKENS=4096

# Production defaults for this deployment
FEATURE_DEV_AGENT=false
FEATURE_DESIGN_AGENT=false
FEATURE_PLAN_SCHEDULER=true
FEATURE_CLAUDE_CODE=false
FEATURE_LOCAL_GENERAL_ACTION=false

# Optional agent / collaboration settings
OPENCLAW_AGENTS=
AGENT_BUS_INBOUND_TOKENS=

# Seedance
ARK_API_KEY=
SEEDDANCE_API_KEY=
SEEDDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDDANCE_MODEL=doubao-seedance-1-0-pro-250528
SEEDDANCE_TIMEOUT=120000
